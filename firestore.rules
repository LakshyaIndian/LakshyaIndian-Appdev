rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'createdAt']);
    }

    // Transcripts
    match /transcripts/{transcriptId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();

      // Messages
      match /messages/{messageId} {
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/transcripts/$(transcriptId)).data.userId == request.auth.uid;
        allow create: if isAuthenticated() && get(/databases/$(database)/documents/transcripts/$(transcriptId)).data.userId == request.auth.uid;
      }
    }
  }
}
